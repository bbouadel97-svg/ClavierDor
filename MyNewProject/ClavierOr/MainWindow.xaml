<Window x:Class="ClavierOr.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Clavier d'Or" Height="760" Width="1120" MinHeight="640" MinWidth="980"
        SizeChanged="Window_SizeChanged"
        Foreground="#FFF1FFF5">
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF060F09" Offset="0"/>
            <GradientStop Color="#FF0E3320" Offset="0.52"/>
            <GradientStop Color="#FF1A5C38" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#AA050F08" Offset="0"/>
            <GradientStop Color="#AA0D3A20" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#1AFFFFFF"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#6645916A"/>
        <SolidColorBrush x:Key="PrimaryButtonBrush" Color="#FF3DAA72"/>
        <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="#FF90DDB0"/>
        <SolidColorBrush x:Key="PrimaryButtonTextBrush" Color="#FF041E10"/>
        <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#55102A1A"/>
        <SolidColorBrush x:Key="SecondaryButtonBorderBrush" Color="#8860BE8E"/>
        <SolidColorBrush x:Key="SecondaryButtonTextBrush" Color="#FFF1FFF5"/>
        <SolidColorBrush x:Key="AnswerButtonBrush" Color="#440D2A1A"/>
        <SolidColorBrush x:Key="AnswerButtonBorderBrush" Color="#AA4A9E6E"/>
        <SolidColorBrush x:Key="AnswerButtonTextBrush" Color="#FFF4FFF8"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FF1A3D2A"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#FF5CB882"/>
        <SolidColorBrush x:Key="ComboItemBackgroundBrush" Color="#FF152B1E"/>
        <SolidColorBrush x:Key="ComboItemHoverBrush" Color="#FF1E6040"/>
        <SolidColorBrush x:Key="ComboItemSelectedBrush" Color="#FF2A7A50"/>
        <SolidColorBrush x:Key="AccentTextBrush" Color="#FF7DEBB0"/>
        <SolidColorBrush x:Key="SoftAccentTextBrush" Color="#FFB8EDD0"/>
        <SolidColorBrush x:Key="StatusTextBrush" Color="#FF88E0AA"/>
        <SolidColorBrush x:Key="HintTextBrush" Color="#FFA0ECC0"/>
        <SolidColorBrush x:Key="InfoCardBorderBrush" Color="#7742896A"/>
        <SolidColorBrush x:Key="InfoCardBackgroundBrush" Color="#14165E30"/>
        <SolidColorBrush x:Key="TipBorderBrush" Color="#6658B882"/>
        <SolidColorBrush x:Key="TipBackgroundBrush" Color="#1A1A5E35"/>
        <SolidColorBrush x:Key="QuestionHighlightBorderBrush" Color="#9960C890"/>
        <SolidColorBrush x:Key="QuestionHighlightBackgroundBrush" Color="#1A0E4022"/>
        <SolidColorBrush x:Key="ProgressPendingBrush" Color="#FFAAC5B4"/>
        <SolidColorBrush x:Key="ProgressPendingStrokeBrush" Color="#FF608D74"/>
        <SolidColorBrush x:Key="GroupBorderBrush" Color="#88429A6A"/>
        <SolidColorBrush x:Key="ListBackgroundBrush" Color="#1A0E4020"/>
        <SolidColorBrush x:Key="DataGridBackgroundBrush" Color="#FF0E3A20"/>
        <SolidColorBrush x:Key="DataGridRowBrush" Color="#FF144A28"/>
        <SolidColorBrush x:Key="DataGridAltRowBrush" Color="#FF1A5C32"/>
        <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#FF236E3E"/>
        <SolidColorBrush x:Key="DataGridGridBrush" Color="#6640886A"/>
        <SolidColorBrush x:Key="DataGridSelectionBrush" Color="#FF3DAA72"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="18" ShadowDepth="0" Color="#CC010F05"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryButtonBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AnswerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AnswerButtonBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AnswerButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AnswerButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="AnswerBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="AnswerBorder" Property="BorderBrush" Value="#FF90DDB0"/>
                                    <Setter TargetName="AnswerBorder" Property="Background" Value="#5D1A5C38"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="AnswerBorder" Property="Background" Value="#88204A30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.025" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.025" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="#FFFFF1F3"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="InputComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFFFF1F3"/>
            <Setter Property="Background" Value="{StaticResource ComboItemBackgroundBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource ComboItemHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource ComboItemSelectedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="#FFFFF1F3"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextElement.Foreground" Value="#FFFFF1F3"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource InputComboBoxItemStyle}"/>
        </Style>
    </Window.Resources>

    <Window.Background>
        <StaticResource ResourceKey="WindowBackgroundBrush"/>
    </Window.Background>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE765;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="CLAVIER D'OR" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Quiz Arena" FontSize="34" FontWeight="Bold" Margin="0,2,0,0"/>
                </StackPanel>

                <Border x:Name="HomePanelBorder" Grid.Row="1" Padding="18" Margin="0,12,0,10" BorderBrush="{StaticResource PanelBorderBrush}" Background="{StaticResource CardBackgroundBrush}" BorderThickness="1" CornerRadius="22" Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Bienvenue dans Clavier d'Or" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Margin="0,6,0,0" FontSize="15" TextWrapping="Wrap" Foreground="{StaticResource SoftAccentTextBrush}"
                                       Text="Un quiz évolutif orienté informatique où chaque rôle change votre stratégie. Préparez votre pseudo, choisissez votre thème, puis enchaînez les questions pour progresser jusqu'au rang Clavier d'Or."/>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="0,0,10,0" Padding="12" CornerRadius="14" BorderBrush="{StaticResource InfoCardBorderBrush}" BorderThickness="1" Background="{StaticResource InfoCardBackgroundBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Comment jouer" FontWeight="Bold" FontSize="15" Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="1) Choisissez votre rôle et un thème."/>
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="2) Répondez vite et juste pour monter le streak."/>
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="3) Sauvegardez vos scores et suivez votre progression."/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="0,0,10,0" Padding="12" CornerRadius="14" BorderBrush="{StaticResource InfoCardBorderBrush}" BorderThickness="1" Background="{StaticResource InfoCardBackgroundBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Rôles spéciaux" FontWeight="Bold" FontSize="15" Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="Mobile: accès aux indices."/>
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="Front-End: peut passer une question."/>
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="Back-End: un rattrapage automatique en cas d'erreur."/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Padding="12" CornerRadius="14" BorderBrush="{StaticResource InfoCardBorderBrush}" BorderThickness="1" Background="{StaticResource InfoCardBackgroundBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Objectif Clavier d'Or" FontWeight="Bold" FontSize="15" Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="Atteignez 70% de réussite pour débloquer les boss."/>
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="Accumulez de l'XP pour monter de niveau."/>
                                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="Vainquez des boss pour obtenir le titre final."/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2" Margin="0,12,0,0" Padding="10" BorderBrush="{StaticResource TipBorderBrush}" BorderThickness="1" CornerRadius="12" Background="{StaticResource TipBackgroundBrush}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEA82;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Top" Margin="0,1,8,0"/>
                                <TextBlock TextWrapping="Wrap" Foreground="#FFFFF1F3" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Text="Astuce: commencez par un thème que vous maîtrisez, puis activez 'Double points' au bon moment pour maximiser votre score."/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Padding="14" Margin="0,0,0,12" BorderBrush="{StaticResource PanelBorderBrush}" Background="{StaticResource CardBackgroundBrush}" BorderThickness="1" CornerRadius="18" Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Joueur" FontWeight="SemiBold"/>
                                <TextBox x:Name="PlayerNameTextBox" Height="34" Margin="0,4,0,0" Style="{StaticResource InputTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Rôle" FontWeight="SemiBold"/>
                                <ComboBox x:Name="RoleComboBox" Height="34" Margin="0,4,0,0" SelectionChanged="RoleComboBox_SelectionChanged" Style="{StaticResource InputComboBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Thème" FontWeight="SemiBold"/>
                                <ComboBox x:Name="ThemeComboBox" Height="34" Margin="0,4,0,0" SelectionChanged="ThemeComboBox_SelectionChanged" Style="{StaticResource InputComboBoxStyle}"/>
                            </StackPanel>
                        </Grid>

                        <WrapPanel Grid.Row="1" Margin="0,14,0,0" HorizontalAlignment="Right" ItemHeight="34">
                            <Button x:Name="NewGameButton" MinWidth="165" Height="34" Margin="0,0,12,8" Style="{StaticResource PrimaryButtonStyle}" Click="NewGameButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Lancer partie" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="ResumeGameButton" MinWidth="180" Height="34" Margin="0,0,12,8" Style="{StaticResource SecondaryButtonStyle}" Click="ResumeGameButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Reprendre partie" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="SaveButton" MinWidth="190" Height="34" Margin="0,0,0,8" Style="{StaticResource SecondaryButtonStyle}" Click="SaveButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Sauvegarder partie" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Grid 
                    x:Name="MainContentGrid" Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*"/>
                        <ColumnDefinition Width="1.3*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="QuestionPanelBorder" Grid.Column="0" Padding="18" BorderBrush="{StaticResource PanelBorderBrush}" Background="{StaticResource CardBackgroundBrush}" BorderThickness="1" Margin="0,0,10,0" CornerRadius="22" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="StatusTextBlock" Text="Prêt" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource StatusTextBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock x:Name="TimerText" Text="--" FontWeight="Bold" FontSize="18" Foreground="#FF3DAA72" VerticalAlignment="Center" Margin="0,0,6,0" MinWidth="28" TextAlignment="Right"/>
                                    <ProgressBar x:Name="TimerBar" Width="90" Height="8" Maximum="30" Value="30" Background="#3340C880" BorderThickness="0" VerticalAlignment="Center">
                                        <ProgressBar.Foreground>
                                            <SolidColorBrush x:Name="TimerBarForeground" Color="#FF3DAA72"/>
                                        </ProgressBar.Foreground>
                                    </ProgressBar>
                                </StackPanel>
                            </Grid>

                            <Border x:Name="QuestionHighlightBorder" Grid.Row="1" Margin="0,12,0,14" Padding="18" BorderBrush="{StaticResource QuestionHighlightBorderBrush}" BorderThickness="2" CornerRadius="18" Background="{StaticResource QuestionHighlightBackgroundBrush}">
                                <TextBlock x:Name="QuestionTextBlock" FontSize="31" FontWeight="Bold" TextWrapping="Wrap" Text="Cliquez sur 'Lancer' pour démarrer." TextAlignment="Center" LineHeight="42"/>
                            </Border>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="True">
                                <UniformGrid x:Name="AnswersPanel" Columns="4" Margin="0,0,0,4" VerticalAlignment="Top"/>
                            </ScrollViewer>

                            <WrapPanel Grid.Row="3" Margin="0,12,0,0">
                                <Button x:Name="HintButton" MinWidth="110" Height="34" Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Click="HintButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xEA82;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Indice" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="SkipButton" MinWidth="160" Height="34" Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Click="SkipButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE893;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Question suivante" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="DoubleButton" MinWidth="130" Height="34" Margin="0,0,0,8" Style="{StaticResource SecondaryButtonStyle}" Click="DoubleButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Double points" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </WrapPanel>

                            <TextBlock x:Name="HintTextBlock" Grid.Row="4" Margin="0,8,0,0" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>

                    <Border x:Name="DashboardPanelBorder" Grid.Column="1" Padding="14" BorderBrush="{StaticResource PanelBorderBrush}" Background="{StaticResource CardBackgroundBrush}" BorderThickness="1" CornerRadius="22" Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Tableau de bord" FontWeight="Bold" FontSize="18" Foreground="{StaticResource AccentTextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border x:Name="StreakBadge" Grid.Column="1" CornerRadius="16" Padding="10,3" Background="#CC1A5C38" Visibility="Collapsed" VerticalAlignment="Center">
                                    <TextBlock x:Name="StreakText" Text="🔥 x0" FontWeight="Bold" FontSize="13" Foreground="#FF7DEBB0"/>
                                </Border>
                            </Grid>
                            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                <TextBlock x:Name="PlayerInfoTextBlock"/>
                                <TextBlock x:Name="ScoreInfoTextBlock" Margin="0,4,0,0"/>
                                <TextBlock x:Name="RoleInfoTextBlock" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <WrapPanel Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,6" VerticalAlignment="Center">
                                        <Ellipse x:Name="ReussiteStepDot" Width="10" Height="10" Fill="{StaticResource ProgressPendingBrush}" Stroke="{StaticResource ProgressPendingStrokeBrush}" StrokeThickness="1" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="ReussiteStepText" Text="Reussite" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,6" VerticalAlignment="Center">
                                        <Ellipse x:Name="BossStepDot" Width="10" Height="10" Fill="{StaticResource ProgressPendingBrush}" Stroke="{StaticResource ProgressPendingStrokeBrush}" StrokeThickness="1" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="BossStepText" Text="Boss" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6" VerticalAlignment="Center">
                                        <Ellipse x:Name="ClavierOrStepDot" Width="10" Height="10" Fill="{StaticResource ProgressPendingBrush}" Stroke="{StaticResource ProgressPendingStrokeBrush}" StrokeThickness="1" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="ClavierOrStepText" Text="Clavier d'Or" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </WrapPanel>
                                <TextBlock x:Name="ProgressionInfoTextBlock" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{StaticResource SoftAccentTextBrush}"/>
                            </StackPanel>

                            <GroupBox Grid.Row="2" Header="Historique" Margin="0,12,0,8" MinHeight="160" Foreground="#FFFFF1F3" BorderBrush="{StaticResource GroupBorderBrush}">
                                <ListBox x:Name="HistoryListBox" Background="{StaticResource ListBackgroundBrush}" Foreground="#FFFFF1F3" BorderThickness="0"/>
                            </GroupBox>

                            <WrapPanel Grid.Row="3" Margin="0,4,0,4">
                                <Button x:Name="FinishButton" MinWidth="120" Height="34" Margin="0,0,8,8" Style="{StaticResource SecondaryButtonStyle}" Click="FinishButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Terminer" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ExportPdfButton" MinWidth="110" Height="34" Margin="0,0,0,8" Style="{StaticResource SecondaryButtonStyle}" Click="ExportPdfButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8DE;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Export PDF" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </WrapPanel>

                            <GroupBox Grid.Row="4" Header="Scores sauvegardés" MinHeight="160" Foreground="#FFFFF1F3" BorderBrush="{StaticResource GroupBorderBrush}">
                                <DataGrid x:Name="ScoresDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Background="{StaticResource DataGridBackgroundBrush}" Foreground="#FFFFFFFF" BorderThickness="0" GridLinesVisibility="Horizontal" RowBackground="{StaticResource DataGridRowBrush}" AlternatingRowBackground="{StaticResource DataGridAltRowBrush}" HorizontalGridLinesBrush="{StaticResource DataGridGridBrush}" VerticalGridLinesBrush="{StaticResource DataGridGridBrush}" AlternationCount="2">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="{StaticResource DataGridHeaderBrush}"/>
                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource DataGridGridBrush}"/>
                                            <Setter Property="BorderThickness" Value="0,0,0.8,1"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource DataGridGridBrush}"/>
                                            <Setter Property="BorderThickness" Value="0.5"/>
                                            <Setter Property="Padding" Value="6,3"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource DataGridSelectionBrush}"/>
                                                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.RowStyle>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                            <Setter Property="Background" Value="{StaticResource DataGridRowBrush}"/>
                                            <Style.Triggers>
                                                <Trigger Property="AlternationIndex" Value="1">
                                                    <Setter Property="Background" Value="{StaticResource DataGridAltRowBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource DataGridSelectionBrush}"/>
                                                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.RowStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Date" Binding="{Binding DatePartie, StringFormat=dd/MM/yyyy HH:mm}" Width="*"/>
                                        <DataGridTextColumn Header="Pseudo" Binding="{Binding Joueur.Pseudo}" Width="*"/>
                                        <DataGridTextColumn Header="Points" Binding="{Binding Points}" Width="80"/>
                                        <DataGridTextColumn Header="Réussite" Binding="{Binding PourcentageReussite, StringFormat={}{0:F0}%}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <StatusBar Grid.Row="1" Margin="0,10,0,0" Background="#2224A855" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1">
            <StatusBarItem>
                <TextBlock x:Name="FooterTextBlock" Text="ORM EF Core actif - prêt."/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
